generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model animaux {
  id              Int               @id @default(autoincrement())
  nom             String
  dateNaissance   DateTime
  type            animaux_type
  espece          String?
  icad            String?
  pbSante         String?
  image           String
  userId          Int
  couleur         String?
  user            user              @relation(fields: [userId], references: [id], map: "Animaux_userId_fkey")
  antiparasitaire antiparasitaire[]
  poids           poids[]
  traitement      traitement[]
  vaccin          vaccin[]
  vermifuge       vermifuge[]

  @@index([userId], map: "Animaux_userId_fkey")
}

model antiparasitaire {
  id         Int      @id @default(autoincrement())
  date       DateTime
  nom        String
  qtite      Float
  dateRappel DateTime
  animauxId  Int
  animaux    animaux  @relation(fields: [animauxId], references: [id], map: "Antiparasitaire_animauxId_fkey")

  @@index([animauxId], map: "Antiparasitaire_animauxId_fkey")
}

model medicament {
  id           Int        @id @default(autoincrement())
  nom          String
  dosage       String
  nbJour       Int
  traitementId Int
  traitement   traitement @relation(fields: [traitementId], references: [id], map: "Medicament_traitementId_fkey")

  @@index([traitementId], map: "Medicament_traitementId_fkey")
}

model poids {
  id       Int      @id @default(autoincrement())
  date     DateTime @default(now())
  kilo     Float
  animalId Int
  animaux  animaux  @relation(fields: [animalId], references: [id], map: "Poids_animalId_fkey")

  @@index([animalId], map: "Poids_animalId_fkey")
}

model traitement {
  id         Int          @id @default(autoincrement())
  animauxId  Int
  dateDebut  DateTime?
  dateFin    DateTime?
  medicament medicament[]
  animaux    animaux      @relation(fields: [animauxId], references: [id], map: "Traitement_animauxId_fkey")

  @@index([animauxId], map: "Traitement_animauxId_fkey")
}

model user {
  id        Int       @id @default(autoincrement())
  email     String    @unique(map: "User_email_key")
  password  String
  createdAt DateTime  @default(now())
  animaux   animaux[]
}

model vaccin {
  id         Int      @id @default(autoincrement())
  date       DateTime
  nom        String
  qtite      Float
  dateRappel DateTime
  animauxId  Int
  animaux    animaux  @relation(fields: [animauxId], references: [id], map: "Vaccin_animauxId_fkey")

  @@index([animauxId], map: "Vaccin_animauxId_fkey")
}

model vermifuge {
  id         Int      @id @default(autoincrement())
  date       DateTime
  nom        String
  qtite      Float
  dateRappel DateTime
  animauxId  Int
  animaux    animaux  @relation(fields: [animauxId], references: [id], map: "Vermifuge_animauxId_fkey")

  @@index([animauxId], map: "Vermifuge_animauxId_fkey")
}

enum animaux_type {
  CHIEN
  CHAT
  OISEAU
  POISSON
  CHEVAUX
  RONGEUR
  REPTILE
  AUTRE
}
